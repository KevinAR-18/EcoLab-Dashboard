}

/* LOGIN CARD */
#loginCard {
    background: rgba(255,255,255,0.85);
    border-radius: 20px;
}

/* INPUT */
QLineEdit {
    background: rgba(255,255,255,0.8);
    border: 1px solid #cbd5e1;
    border-radius: 8px;
    padding: 6px;
}

/* BUTTON PRIMARY */
QPushButton#loginButton {
    background-color: #2f80ed;
    color: white;
    border-radius: 8px;
    padding: 10px;
    font-weight: bold;
}

QPushButton#loginButton:hover {
    background-color: #1c6dd0;
}

/* BUTTON GUEST */
QPushButton#guestButton {
    background-color: #3c8ce7;
    color: white;
    border-radius: 8px;
    padding: 10px;
}

/* GOOGLE BUTTON */
QPushButton#googleButton {
    background: white;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    padding: 8px;
}

QPushButton {
    font-size: 13px;
}

