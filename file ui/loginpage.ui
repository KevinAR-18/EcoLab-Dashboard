            <property name="styleSheet">
             <string notr="true">QPushButton#closeAppBtn {
    background-color: #5A8BD8;       /* biru kalem, agak gelap dari background */
    border: none;
    border-radius: 12px;             /* rounded corners */
    color: white;
    font-weight: bold;
    font-size: 14px;
}
QPushButton#closeAppBtn:hover {
    background-color: #4672C4;       /* biru lebih gelap saat hover */
}
QPushButton#closeAppBtn:pressed {
    background-color: #3B5CA0;       /* biru lebih gelap saat ditekan */
}</string>
