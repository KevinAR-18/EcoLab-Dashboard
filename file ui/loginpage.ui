   <property name="styleSheet">
    <string notr="true">

/* BACKGROUND */

QWidget{

}



/* LOGIN CARD */

#loginpageFrame {
    border-top: 3px solid #005C99;

    background: qlineargradient(
        x1:0, y1:0, x2:0, y2:1,
        stop:0 #E1F2FB,
        stop:1 #F1F9F9
    );

    background-image: url(:/images/images/images/bg5.png);
    background-repeat: no-repeat;
    background-position: top;
    border-radius:18px;
border: 1px solid #D9E9F6;
}

/* INPUT */

QLineEdit{
background:white;
border:1px solid #cfd8e3;
border-radius:8px;
padding:8px;
font-size:12pt;
}

QLineEdit:focus{
border:1px solid #2b6cb0;
}

/* BUTTON GLOBAL */

QPushButton{
border-radius:10px;
padding:8px;
font-weight:bold;
}

/* PRIMARY */

#signinButton,#signupButton{
background-color:#2b6cb0;
color:white;
}

#signinButton:hover,#signupButton:hover{
background-color:#1e4f8a;
}

/* GUEST */

#guestButton{
background:#4c8ed9;
color:white;
}

#guestButton:hover{
background:#3979c7;
}

/* GOOGLE - IMAGE BUTTONS */

#googleSigninButton,#googleSignupButton{
background:transparent;
border:none;
}

#googleSigninButton:hover,#googleSignupButton:hover{
background:transparent;
opacity:0.8;
}

/* OR LABEL */

#orLabel{
font-size:10pt;
font-weight:bold;
color:#5b6f82;
}

/* LINK BUTTON */

#goto_signuppage,#goto_signinpage{
background:transparent;
color:#2b6cb0;
border:none;
font-weight:bold;
}

#goto_signuppage:hover,#goto_signinpage:hover{
text-decoration:underline;
}

</string>
