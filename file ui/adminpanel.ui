   <property name="styleSheet">
    <string notr="true">
/* Title Menu */
#titleRightInfo { padding-left: 10px; }
#titleRightInfo { 
    font: 12pt &quot;Segoe UI&quot;; 
    color: #FFFFFF;
	font-weight: 700;
}

#clockInfo { 
    font: 10pt &quot;Segoe UI&quot;; 
    color: #FFFFFF;

}

#contentTop {	
	background-color: #002B5B;
	border: 1px solid #003F7D;
}

#contentBottom {
    border-top: 3px solid #005C99;

    background: qlineargradient(
        x1:0, y1:0, x2:0, y2:1,
        stop:0 #E1F2FB,
        stop:1 #F1F9F9
    );

    border-image: url(:/images/images/images/bg5.png) 0 0 0 0 stretch stretch;
}

/* Top Buttons */
#rightButtons .QPushButton { background-color: rgba(255, 255, 255, 0); border: none;  border-radius: 5px; }
#rightButtons .QPushButton:hover { background-color: #003F7D; border-style: solid; border-radius: 4px; }
#rightButtons .QPushButton:pressed { background-color: #002B5B; border-style: solid; border-radius: 4px; }

/* ================= TABLE ================= */
QTableWidget {
    background-color: #FFFFFF;
    alternate-background-color: #F4FAFF;
    gridline-color: #D6EAF8;

    border: 1px solid #005C99;   /* border biru */
    border-radius: 10px;         /* rounded utama */

    color: #002B5B;
    font-size: 11pt;
    font-weight: 600;

    selection-background-color: #005C99;
    selection-color: #FFFFFF;
}

/* ================= ITEM ================= */
QTableWidget::item {
    border-bottom: 1px solid #E1F2FB;
    padding: 8px;
    font-weight: 600;
}

QTableWidget::item:hover {
    background-color: #E8F4FC;
}

QTableWidget::item:selected {
    background-color: #005C99;
    color: #FFFFFF;
}

/* ================= HEADER (BIAR NYATU &amp; ROUNDED LOOK) ================= */
QHeaderView {
    background-color: #003F7D;   /* base header */
    border-top-left-radius: 10px;
    border-top-right-radius: 10px;
}

QHeaderView::section {
    background-color: transparent; /* ikut parent biar nyatu */
    color: #FFFFFF;
    padding: 10px 8px;
    border: none;
    font-weight: bold;
    font-size: 11pt;
}

/* ================= COMBOBOX (ROLE DROPDOWN) ================= */
QTableWidget QComboBox {
    background-color: #FFFFFF;
    border: 1px solid #005C99;
    border-radius: 5px;
    padding: 4px 8px;
    font-weight: 600;
    font-size: 10pt;
    color: #002B5B;
}

QTableWidget QComboBox:hover {
    background-color: #E8F4FC;
    border: 1px solid #003F7D;
}

QTableWidget QComboBox::drop-down {
    border: none;
    width: 20px;
}

QTableWidget QComboBox::down-arrow {
    image: url(none);
    border: 2px solid #005C99;
    width: 8px;
    height: 8px;
    background-color: #005C99;
}

QTableWidget QComboBox QAbstractItemView {
    background-color: #FFFFFF;
    border: 1px solid #005C99;
    selection-background-color: #005C99;
    selection-color: #FFFFFF;
    padding: 4px;
}

/* ================= CORNER ================= */
QTableCornerButton::section {
    background-color: #003F7D;
    border: none;
}

/* ================= SCROLLBAR VERTICAL ================= */
QTableWidget QScrollBar:vertical {
    background: transparent;
    width: 12px;
    margin: 4px 2px 4px 2px;
}

QTableWidget QScrollBar::handle:vertical {
    background: #005C99;
    border-radius: 5px;
    min-height: 20px;
}

QTableWidget QScrollBar::handle:vertical:hover {
    background: #003F7D;
}

QTableWidget QScrollBar::handle:vertical:pressed {
    background: #002B5B;
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    height: 0px;
}

/* ================= SCROLLBAR HORIZONTAL ================= */
QTableWidget QScrollBar:horizontal {
    background: transparent;
    height: 10px;
    margin: 2px;
}

QTableWidget QScrollBar::handle:horizontal {
    background: #005C99;
    border-radius: 5px;
    min-width: 20px;
}

QTableWidget QScrollBar::handle:horizontal:hover {
    background: #003F7D;
}

QTableWidget QScrollBar::handle:horizontal:pressed {
    background: #002B5B;
}

QScrollBar::add-line:horizontal,
QScrollBar::sub-line:horizontal {
    width: 0px;
}

#infoaccountFrame QFrame {
    background-color: #EDF6FC;   /* biru sangat pucat */
    border: 2px solid #D9E9F6; /* garis tipis, hampir menyatu */
    border-radius: 12px;
    margin: 4px;
    padding: 8px 0;
}

#infoaccountFrame QLabel {
    border: none;              /* hapus border default */
    background: transparent;    /* pastikan tidak ada background */
    color: #0b3d91;            /* warna font */
    font-weight: bold;
    font-size: 36px;
}


</string>
